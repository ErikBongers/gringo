{
  "include": ["typescript/**/*"],
  "exclude": [],
  "compilerOptions": {
    "outDir": "./generated",
    "target": "esnext",
    "sourceMap": true,
    "noEmit": true,
    "incremental": false,
    "moduleResolution": "bundler",
    "noImplicitOverride": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "strict": true,
    "paths": {
    },
    "typeRoots": ["node_modules/@types"],
    "types": [ "chrome", "node" ]
  },
}